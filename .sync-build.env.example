# Example values for non-interactive `build.sh` runs via sync.
# Copy to .sync-build.env and keep it private (gitignored).

OPENCLAW_ACCESS_MODE=ssh-tunnel
OVH_ENDPOINT_API_KEY=replace_me
OPENCLAW_TOKEN=
OPENCLAW_DIR=$HOME/openclaw
OPENCLAW_CONFIG_DIR=$HOME/.openclaw
OPENCLAW_WORKSPACE_DIR=$HOME/.openclaw/workspace
OPENCLAW_USER=$USER
DRY_RUN=0
