# syntax=docker/dockerfile:1
FROM __CUSTOM_OPENCLAW_BASE_IMAGE__

USER root

ARG DEBIAN_FRONTEND=noninteractive
ARG SIGNAL_CLI_VERSION=0.13.18
ARG OPENCODE_NPM_PACKAGE=@opencode-ai/cli

# System/runtime deps + gh + npm
# Java runtime note: prefer OpenJDK 21; fall back to OpenJDK 17 when the
# underlying distro repositories do not publish openjdk-21-jre-headless.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    gnupg \
    npm \
    gh \
    cargo \
  && if apt-cache show openjdk-21-jre-headless >/dev/null 2>&1; then \
       apt-get install -y --no-install-recommends openjdk-21-jre-headless; \
     elif apt-cache show openjdk-17-jre-headless >/dev/null 2>&1; then \
       apt-get install -y --no-install-recommends openjdk-17-jre-headless; \
     else \
       echo "No supported OpenJDK headless runtime package found (expected 21 or 17)." >&2; \
       exit 1; \
     fi \
  && rm -rf /var/lib/apt/lists/*

# Himalaya CLI (Cargo path for portability)
RUN cargo install --locked himalaya

# Coding-agent backends
RUN npm i -g \
    @openai/codex \
    @anthropic-ai/claude-code \
    @mariozechner/pi-coding-agent \
    "${OPENCODE_NPM_PACKAGE}"

# signal-cli (Linux native)
RUN curl -fsSL "https://github.com/AsamK/signal-cli/releases/download/v${SIGNAL_CLI_VERSION}/signal-cli-${SIGNAL_CLI_VERSION}-Linux-native.tar.gz" -o /tmp/signal-cli.tgz \
  && tar -xzf /tmp/signal-cli.tgz -C /opt \
  && ln -sfn "/opt/signal-cli-${SIGNAL_CLI_VERSION}/bin/signal-cli" /usr/local/bin/signal-cli \
  && rm -f /tmp/signal-cli.tgz

# Optional browser/runtime deps for agent-browser workflows
ARG CUSTOM_OPENCLAW_BROWSER_DEPS=0
RUN if [ "$CUSTOM_OPENCLAW_BROWSER_DEPS" = "1" ]; then \
      apt-get update \
      && apt-get install -y --no-install-recommends \
        chromium \
        fonts-liberation \
        libasound2 \
        libatk-bridge2.0-0 \
        libatk1.0-0 \
        libcups2 \
        libdbus-1-3 \
        libdrm2 \
        libgbm1 \
        libgtk-3-0 \
        libnss3 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxkbcommon0 \
        libxrandr2 \
        xdg-utils \
      && rm -rf /var/lib/apt/lists/*; \
    fi

# Validate installed binaries at build time
RUN gh --version \
  && himalaya --version \
  && codex --version \
  && claude --version \
  && opencode --version \
  && pi --version \
  && signal-cli --version

USER node
